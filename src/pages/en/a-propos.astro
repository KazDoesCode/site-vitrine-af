---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { company, values, images, siteUrl } from "@/config/site";
import { t } from "@/config/i18n";
const locale = "en" as const;
const tr = t(locale);
---
<BaseLayout title={`${tr.aboutPage.eyebrow} — ${company.name}`} description={tr.aboutPage.description} ogImage={`${siteUrl}${images.about}`} locale={locale}>
  <section class="bg-secondary py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent mb-3">{tr.aboutPage.eyebrow}</p>
      <h1 class="font-serif text-3xl sm:text-4xl text-primary leading-tight max-w-2xl">{tr.aboutPage.title}</h1>
      <p class="mt-4 text-base text-gray-600 leading-relaxed max-w-2xl">{tr.aboutPage.description}</p>
    </div>
  </section>
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 grid lg:grid-cols-2 gap-12 items-center">
      <img src={images.about} alt="Consultation" class="w-full h-[440px] object-cover rounded-md" loading="lazy" width="1200" height="800" />
      <div>
        <h2 class="font-serif text-3xl text-primary">{tr.aboutPage.expertiseTitle}</h2>
        <p class="mt-4 text-gray-600 leading-relaxed">{tr.aboutPage.expertiseP1}</p>
        <p class="mt-4 text-gray-600 leading-relaxed">{tr.aboutPage.expertiseP2}</p>
      </div>
    </div>
  </section>
  <section class="py-20 bg-secondary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent mb-3">{tr.aboutPage.valuesEyebrow}</p>
        <h2 class="font-serif text-3xl sm:text-4xl text-primary leading-tight">{tr.aboutPage.valuesTitle}</h2>
      </div>
      <div class="mt-12 grid gap-7 sm:grid-cols-2">
        {values.map((v) => (
          <div class="bg-white border border-gray-200 p-7 rounded-md">
            <h3 class="font-serif text-2xl text-primary">{v.title}</h3>
            <p class="mt-3 text-gray-600 leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/en/contact" class="inline-flex items-center justify-center rounded-md bg-accent px-8 py-3.5 text-sm font-semibold text-white hover:bg-accent-dark transition-colors">{tr.aboutPage.cta}</a>
      </div>
    </div>
  </section>
</BaseLayout>
