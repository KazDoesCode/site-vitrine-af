---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { company, values, images, siteUrl } from "@/config/site";
import { t } from "@/config/i18n";

const locale = "fr";
const tr = t(locale);
---

<BaseLayout
  title={`${tr.aboutPage.eyebrow} — ${company.name}`}
  description="Découvrez notre cabinet spécialisé en démarches administratives : accompagnement, transparence, réactivité, confidentialité. Plus de 10 ans d'expertise à Paris."
  ogImage={`${siteUrl}${images.about}`}
  locale={locale}
>
  <section class="bg-secondary py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent mb-3">{tr.aboutPage.eyebrow}</p>
      <h1 class="font-serif text-3xl sm:text-4xl text-primary leading-tight max-w-2xl">{tr.aboutPage.title}</h1>
      <p class="mt-4 text-base text-gray-600 leading-relaxed max-w-2xl">{tr.aboutPage.description}</p>
    </div>
  </section>

  <section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div class="absolute -inset-3 bg-secondary rounded-2xl -z-10"></div>
        <img
          src={images.about}
          alt="Consultation administrative"
          class="w-full h-[440px] object-cover rounded-xl shadow-lg"
          loading="lazy" width="1200" height="800"
        />
      </div>
      <div>
        <h2 class="font-serif text-3xl text-primary">{tr.aboutPage.expertiseTitle}</h2>
        <p class="mt-4 text-gray-600 leading-relaxed">{tr.aboutPage.expertiseP1}</p>
        <p class="mt-4 text-gray-600 leading-relaxed">{tr.aboutPage.expertiseP2}</p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-secondary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent mb-3">{tr.aboutPage.valuesEyebrow}</p>
        <h2 class="font-serif text-3xl sm:text-4xl text-primary leading-tight">{tr.aboutPage.valuesTitle}</h2>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2">
        {values.map((v) => (
          <div class="group bg-white border border-gray-100 rounded-xl p-8 shadow-sm hover:shadow-md hover:border-accent/30 transition-all duration-300">
            <div class="w-10 h-1 bg-accent rounded-full mb-5 group-hover:w-14 transition-all duration-300"></div>
            <h3 class="font-serif text-2xl text-primary">{v.title}</h3>
            <p class="mt-3 text-gray-600 leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-14">
        <a href="/contact" class="btn-primary">{tr.aboutPage.cta}</a>
      </div>
    </div>
  </section>
</BaseLayout>
