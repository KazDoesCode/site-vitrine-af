---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { company, contact, googleCalendarAppointmentUrl } from "@/config/site";
import { t } from "@/config/i18n";

const locale = "fr";
const tr = t(locale);
const ap = tr.appointmentPage;
---

<BaseLayout title={`${ap.eyebrow} — ${company.name}`} description={ap.description} locale={locale}>
  <section class="bg-secondary py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent mb-3">{ap.eyebrow}</p>
      <h1 class="font-serif text-3xl sm:text-4xl text-primary leading-tight max-w-2xl">{ap.title}</h1>
      <p class="mt-4 text-base text-gray-600 leading-relaxed max-w-2xl">{ap.description}</p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 grid lg:grid-cols-3 gap-12">

      <!-- Carte principale : réserver via Google Calendar -->
      <div class="lg:col-span-2">
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
          <div class="bg-primary px-8 py-6">
            <div class="flex items-center gap-4">
              <div class="bg-white/10 rounded-full p-3">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <div>
                <h2 class="font-serif text-2xl text-white">{ap.calendarTitle}</h2>
                <p class="text-sm text-white/70 mt-0.5">{ap.calendarSubtitle}</p>
              </div>
            </div>
          </div>
          <div class="px-8 py-10 text-center space-y-6">
            <p class="text-gray-600 text-base max-w-md mx-auto leading-relaxed">
              Cliquez sur le bouton ci-dessous pour accéder à notre agenda en ligne et choisir le créneau qui vous convient.
            </p>
            <a
              href={googleCalendarAppointmentUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 rounded-md bg-accent px-10 py-4 text-base font-semibold text-white hover:bg-accent-dark hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 shadow-md"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              Choisir mon créneau
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
            <p class="text-xs text-gray-400">S'ouvre dans un nouvel onglet · Google Calendar</p>
          </div>
        </div>
      </div>

      <!-- Colonne latérale : autres moyens de contact -->
      <aside class="space-y-6">
        <h2 class="font-serif text-xl text-primary">{ap.orTitle}</h2>
        <div class="space-y-3">
          <a
            href={`https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(contact.whatsappMessage)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 rounded-md bg-[#25D366] px-5 py-3.5 text-sm font-semibold text-white hover:bg-[#1ebe5a] transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            {ap.whatsappCta}
          </a>
          <a
            href={`tel:${contact.phone}`}
            class="flex items-center gap-3 rounded-md border border-primary px-5 py-3.5 text-sm font-semibold text-primary hover:bg-primary hover:text-white transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.08 1.18 2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/>
            </svg>
            {contact.phoneDisplay}
          </a>
          <a
            href={`mailto:${contact.email}`}
            class="flex items-center gap-3 rounded-md border border-gray-300 px-5 py-3.5 text-sm font-semibold text-gray-700 hover:border-primary hover:text-primary transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            {contact.email}
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
