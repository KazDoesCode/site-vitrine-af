---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { company, services } from "@/config/site";
import { t } from "@/config/i18n";

const locale = "fr";
const tr = t(locale);
---

<BaseLayout
  title={`${tr.servicesPage.eyebrow} — ${company.name}`}
  description="Titre de séjour, renouvellement, autorisation de travail, naturalisation, regroupement familial : découvrez tous nos services."
  locale={locale}
>
  <section class="bg-secondary py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent mb-3">{tr.servicesPage.eyebrow}</p>
      <h1 class="font-serif text-3xl sm:text-4xl text-primary leading-tight max-w-2xl">{tr.servicesPage.title}</h1>
      <p class="mt-4 text-base text-gray-600 leading-relaxed max-w-2xl">{tr.servicesPage.description}</p>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 space-y-24">
      {services.map((service, idx) => (
        <article id={service.slug} class="grid lg:grid-cols-2 gap-12 items-center scroll-mt-24">
          <div class={`relative ${idx % 2 === 1 ? "lg:order-2" : ""}`}>
            <div class="absolute -inset-3 bg-secondary rounded-2xl -z-10"></div>
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-[360px] object-cover rounded-xl shadow-lg"
              loading="lazy" width="1000" height="700"
            />
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
              {tr.servicesPage.serviceLabel} {String(idx + 1).padStart(2, "0")}
            </p>
            <h2 class="mt-3 font-serif text-3xl text-primary">{service.title}</h2>
            <p class="mt-4 text-gray-600 leading-relaxed">{service.summary}</p>
            <ul class="mt-5 space-y-2 text-sm text-gray-800">
              {tr.servicesPage.bullets.map((b) => (
                <li class="flex gap-2 items-start">
                  <span class="text-accent font-bold mt-0.5">▸</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn-primary mt-8">
              {tr.servicesPage.cta}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
